; Engine configuration file.
; Keystone — a beaver game.

config_version=5

[application]

config/name="Keystone"
config/description="A beaver builds a wetland. Win when 6 species coexist for 3 days."
run/main_scene="res://scenes/TitleScreen.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Game="*res://scripts/game.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=640
window/size/window_width_override=1280
window/size/window_height_override=854
window/stretch/mode="viewport"
window/stretch/aspect="keep"

